# OrangeHRM BDD Automation Framework Environment Configuration Template
# Copy this file to '.env' and fill in your settings before running tests.

# --- Application Configuration ---
BASE_URL=https://opensource-demo.orangehrmlive.com
API_BASE_URL=https://opensource-demo.orangehrmlive.com/web/index.php

# --- Test User Credentials ---
ADMIN_USERNAME=Admin
ADMIN_PASSWORD=admin123

# --- Playwright Browser Configuration ---
# Options: chromium, firefox, webkit
BROWSER=chromium
HEADLESS=true
TIMEOUT=60000

# --- Parallel Run Configurations ---
# Number of concurrent workers for parallel feature file execution
PARALLEL_WORKERS=3

# --- Reporting & Outputs ---
ALLURE_RESULTS_DIR=reports/allure-results
LOGS_DIR=logs
TRACES_DIR=reports/traces
VIDEOS_DIR=reports/videos_failures
# Set to true to automatically launch the Allure serve dashboard after execution
AUTO_OPEN_REPORT=true

# --- AI Resiliency & Self-Healing Features ---
# Paste your Google Gemini API key to enable self-healing and failure analysis
GEMINI_API_KEY=your_gemini_api_key_here
# Toggle self-healing locators dynamically on failure/timeout (true/false)
AI_SELF_HEALING=true
# Toggle plain English diagnostic reporting on failures (true/false)
AI_FAILURE_ANALYSIS=true
